# Copy this to .env and adjust for your local runtime.

# Lab automation credentials
LAB_VM_USER=your_lab_user
LAB_VM_PASS=your_lab_password

# Runtime inputs
NIDS_INTERFACE=
NIDS_PCAP_DIR=pcaps
NIDS_LABELS_PATH=

# Runtime config paths
NIDS_RULES_PATH=rules/rules.yml
NIDS_CONFIG_PATH=config/nids.yml
NIDS_OUTPUT_DIR=output
NIDS_DB_PATH=output/nids.db
NIDS_SENSOR_ID=sensor-docker

# Optional ML runtime settings
NIDS_MODEL_PATH=
NIDS_UNSUPERVISED=0

# Dashboard auth (optional)
DASHBOARD_TOKEN=
DASHBOARD_ACTION_TOKEN=

# Optional API replay auth key
UNIVERSAL_NIDS_API_KEY=

# Host port published for dashboard
DASHBOARD_PORT=8000

# Optional local AI explanation through Ollama
NIDS_OLLAMA_ENABLED=false
NIDS_OLLAMA_BASE_URL=http://localhost:11434
NIDS_OLLAMA_MODEL=llama3.1:8b
NIDS_OLLAMA_TIMEOUT_SECONDS=8

# Cloud single-node storage roots (used by docker-compose.cloud-single-node.yml)
# For remote VM deployment, set these to bounded paths under /opt/universal-nids/cloud_data.
# Keep the dashboard disabled unless you access it through an SSH tunnel.
NIDS_CLOUD_RUNTIME_OUTPUT_DIR=./cloud_data/runtime/output
NIDS_CLOUD_RUNTIME_LOG_DIR=./cloud_data/runtime/logs
NIDS_CLOUD_RUNTIME_REPORTS_DIR=./cloud_data/runtime/reports
NIDS_CLOUD_RUNTIME_ARTIFACTS_DIR=./cloud_data/runtime/artifacts
NIDS_CLOUD_LAB_BUNDLES_DIR=./cloud_data/lab_generated/bundles
NIDS_CLOUD_REPLAY_DIR=./cloud_data/replay/staging

# Optional alert/incident notifications
NIDS_SLACK_WEBHOOK=
NIDS_NOTIFY_MIN_SEVERITY=high
NIDS_NOTIFY_TIMEOUT_SEC=3
NIDS_NOTIFY_MAX_RETRIES=2
NIDS_NOTIFY_BACKOFF_SEC=0.5
NIDS_NOTIFY_MAX_BACKOFF_SEC=4
NIDS_NOTIFY_MIN_INTERVAL_SEC=0.1
NIDS_NOTIFY_DEAD_LETTER=output/notification_failures.jsonl
NIDS_NOTIFY_DEAD_LETTER_MAX_BYTES=10485760
NIDS_NOTIFY_DEAD_LETTER_BACKUP_COUNT=5
