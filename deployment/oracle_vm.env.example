# Copy this file to deployment/oracle_vm.env and fill in your Oracle VM values.
# Do not commit deployment/oracle_vm.env.
# Keep ORACLE_VM_SSH_KEY_PATH in ~/.ssh/... or C:/Users/... form so the same
# file works in both Bash and PowerShell helpers.

# Required remote connection defaults
ORACLE_VM_HOST=
ORACLE_VM_USER=ubuntu
ORACLE_VM_SSH_KEY_PATH=~/.ssh/universal_nids_oracle
ORACLE_VM_SSH_PORT=22
ORACLE_VM_PROJECT_DIR=/opt/universal-nids
ORACLE_VM_REMOTE_UPLOAD_DIR=/tmp/universal-nids-upload

# Optional local convenience defaults
ORACLE_VM_LOCAL_REPO=
ORACLE_VM_SYNC_METHOD=rsync
ORACLE_VM_RUN_MODE=replay
ORACLE_VM_SENSOR_ID=oracle-cloud
ORACLE_VM_LOCAL_LAB_BUNDLE=
ORACLE_VM_COLLECTION_DIR=
